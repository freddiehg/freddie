{
  "name": "mercury-bridge",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm run icons && tsc",
    "watch": "pnpm run icons && tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "icons": "mkdir -p icons && cp ../crates/mercury/assets/mercury.png icons/"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/chrome": "^0.2.2",
    "eslint": "^9",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8"
  }
}
